# ── App ───────────────────────────────────────────────────────
APP_ENV=development                  # development | production
APP_SECRET_KEY=change-me-in-prod
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://geopulse:password@localhost:5432/geopulse
DATABASE_URL_SYNC=postgresql://geopulse:password@localhost:5432/geopulse  # for Alembic

# ── Redis (Celery broker) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── NLP models ────────────────────────────────────────────────
# Set to "onnx" for CPU-optimised quantized inference (recommended for prod)
# Set to "hf" to use full HuggingFace models (slower on CPU, good for dev)
NLP_INFERENCE_MODE=onnx
MODEL_CACHE_DIR=../data/models

# ── Data sources ──────────────────────────────────────────────
# GDELT is free — no key needed
# Yahoo Finance is free — no key needed
# Add NewsAPI key for broader coverage (free tier: 100 req/day)
NEWSAPI_KEY=

# ── Market data ───────────────────────────────────────────────
# FRED API key — free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── Alerts (optional) ─────────────────────────────────────────
# Resend for email alerts (free tier: 3000 emails/month)
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@yourdomain.com

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,https://yourdomain.vercel.app

# ── Ingestion schedule ────────────────────────────────────────
INGEST_INTERVAL_MINUTES=15
NLP_BATCH_SIZE=32
